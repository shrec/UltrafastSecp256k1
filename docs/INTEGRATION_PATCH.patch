# Base: bitcoin/bitcoin commit 0abbe35
#       "Merge bitcoin/bitcoin#35148: refactor: Remove confusing DataStream::in_avail() alias"
#       (latest upstream merge in shrec/bitcoin fork as of 2026-05-07)
#
# Fork: github.com/shrec/bitcoin  branch: feature/ultrafast-secp256k1-backend
# Build preset: cmake --preset ultrafast-bench  (Release + LTO)
#
# Commits applied on top of base (oldest → newest):
#   e3040fb build: add SECP256K1_BACKEND=ultrafast compile-time alternative
#   d1f65b1 build: switch ultrafast backend to submodule, remove FetchContent
#   fb1edf7 build: point ultrafast_secp256k1 submodule to dev branch
#   f087ac0 build: bump ultrafast_secp256k1 submodule (MuSig2 shim complete)
#   66b4048 chore: bump ultrafast_secp256k1 submodule (schnorr/musig/context fixes)
#   a283ff7 chore: bump ultrafast_secp256k1 (schnorr_verify array type fix)
#   0b7e9ec chore: bump ultrafast_secp256k1 (ellswift y-parity fix)
#   c3a2021 chore: bump ultrafast_secp256k1 (ellswift create_fast y-parity fix)
#   2d4e5b3 chore: bump UltrafastSecp256k1 (musig2 Y-parity + hybrid pubkey fixes)
#   ad18551 chore: bump ultrafast_secp256k1 to latest dev (perf + security fixes)
#   d5438d5 chore: bump ultrafast_secp256k1 (ct_point + ellswift y-parity fixes)
#   be269c3 chore: bump ultrafast_secp256k1 (bip324 backend + ct prebuilt tables)
#   d4d49ce chore: bump ultrafast_secp256k1 (zero-write verify + LTO discovery)
#   5794d03 chore: add ultrafast-bench/libsecp-bench presets + LTO as default build
#
# Files changed (excluding src/ultrafast_secp256k1 submodule directory):
#   .gitignore          — add out/ and build-*/ to gitignore
#   .gitmodules         — register src/ultrafast_secp256k1 submodule
#   CMakePresets.json   — add ultrafast-bench and libsecp-bench presets
#   cmake/secp256k1.cmake — backend selection logic (SECP256K1_BACKEND variable)
#   src/CMakeLists.txt  — guard add_secp256k1() call behind backend check
#
# To apply against a clean Bitcoin Core checkout:
#   git clone https://github.com/bitcoin/bitcoin && cd bitcoin
#   git checkout 0abbe35   # or the equivalent upstream state
#   git apply /path/to/INTEGRATION_PATCH.patch
#   git submodule update --init src/ultrafast_secp256k1
#   cmake --preset ultrafast-bench
#   cmake --build out/build-ultrafast-lto -j$(nproc)
#   ctest --test-dir out/build-ultrafast-lto -j$(nproc)
#
# NOTE: The submodule (src/ultrafast_secp256k1) is NOT included in this patch.
# It must be initialised separately via git submodule update --init.
# The .gitmodules entry below points to github.com/shrec/UltrafastSecp256k1 (branch: dev).

