{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/${presetName}",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "base-linux",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "base-windows",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "generator": "Ninja"
    },
    {
      "name": "cpu-release",
      "displayName": "CPU Release (Safe)",
      "description": "CPU-only optimized build with safe defaults (stack protector, FORTIFY_SOURCE active)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_BENCH": "ON",
        "SECP256K1_SPEED_FIRST": "OFF",
        "SECP256K1_ENABLE_OPENMP": "ON"
      }
    },
    {
      "name": "windows-clang-cl",
      "displayName": "Windows clang-cl (Clang codegen, MSVC ABI)",
      "description": "Build with clang-cl on Windows: Clang's inline MULX/ADCX field kernels in an MSVC-compatible toolchain (link.exe, MSVC CRT, VS-integrable). ~3.3-3.6x faster scalar_mul/batch_verify than MSVC cl, near clang++ parity. compiler-rt builtins auto-linked; ThinLTO disabled (broken on windows-msvc).",
      "inherits": "cpu-release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "SECP256K1_USE_LTO": "OFF"
      }
    },
    {
      "name": "windows-arm64-clang-cl",
      "displayName": "Windows ARM64 clang-cl (MSVC ABI)",
      "description": "Build for Windows ARM64 with clang-cl and the MSVC ABI. AArch64 NEON is the architectural SIMD baseline; compiler-rt aarch64 builtins are auto-linked.",
      "inherits": "windows-clang-cl",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_SYSTEM_PROCESSOR": "ARM64",
        "CMAKE_C_COMPILER_TARGET": "aarch64-pc-windows-msvc",
        "CMAKE_CXX_COMPILER_TARGET": "aarch64-pc-windows-msvc"
      }
    },
    {
      "name": "cpu-release-speed",
      "displayName": "CPU Release (Speed-First, UNSAFE)",
      "description": "CPU-only maximum throughput: -Ofast, no stack protector, no FORTIFY_SOURCE. Use only in controlled environments.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_BENCH": "ON",
        "SECP256K1_SPEED_FIRST": "ON",
        "SECP256K1_ENABLE_OPENMP": "ON"
      }
    },
    {
      "name": "cpu-debug",
      "displayName": "CPU Debug",
      "description": "CPU-only debug build",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "arm64-cross",
      "displayName": "ARM64 Cross (Linux \u2192 AArch64)",
      "description": "Cross-compile CPU-only release for AArch64/ARM64 using aarch64-linux-gnu-gcc",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-aarch64-linux-gnu.cmake",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_OPENCL": "OFF",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_BENCH": "ON"
      }
    },
    {
      "name": "riscv64-cross",
      "displayName": "RISC-V 64 Cross (Linux \u2192 rv64gc)",
      "description": "Cross-compile CPU-only release for RISC-V 64-bit (rv64gc_zba_zbb) using riscv64-linux-gnu-gcc",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-riscv64-linux-gnu.cmake",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_OPENCL": "OFF",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_BENCH": "ON"
      }
    },
    {
      "name": "cuda-release",
      "displayName": "CUDA Release (Linux)",
      "description": "CPU + CUDA GPU optimized build for Linux",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "ON",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_BENCH": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "native",
        "CMAKE_CUDA_SEPARABLE_COMPILATION": "ON",
        "SECP256K1_ENABLE_OPENMP": "ON"
      }
    },
    {
      "name": "cuda-debug",
      "displayName": "CUDA Debug (Linux)",
      "description": "CPU + CUDA GPU debug build for Linux",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "ON",
        "SECP256K1_BUILD_TESTS": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "native",
        "CMAKE_CUDA_SEPARABLE_COMPILATION": "ON"
      }
    },
    {
      "name": "cuda-release-5060ti",
      "displayName": "CUDA Release RTX 5060 Ti",
      "description": "RTX 5060 Ti is Blackwell (compute capability 12.0 / sm_120), not Ada/SM 8.9 -- uses the ci-bounded-recent named profile (89-real;89-virtual;120-real;120-virtual, nvcc >= 13.0 required) for real deterministic sm_120 coverage. This host's default `nvcc` on PATH resolves to CUDA 12.0 (ceiling compute_90), so CMAKE_CUDA_COMPILER is pinned explicitly to the installed CUDA 13.2 toolkit -- without this pin, a fresh invocation of this preset would resolve nvcc 12.0 and FATAL_ERROR on the ci-bounded-recent version guard instead of building sm_120. This is a named local-hardware preset: the path is specific to this documented host, not a portable default (generic/portable presets must not hardcode it). See cmake/CUDA_ARCHITECTURE_POLICY.md.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "ON",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_BENCH": "ON",
        "SECP256K1_CUDA_ARCH_PROFILE": "ci-bounded-recent",
        "CMAKE_CUDA_SEPARABLE_COMPILATION": "ON",
        "SECP256K1_ENABLE_OPENMP": "ON",
        "CMAKE_CUDA_COMPILER": "/usr/local/cuda-13.2/bin/nvcc"
      }
    },
    {
      "name": "base-coin",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_OPENCL": "OFF",
        "SECP256K1_BUILD_TESTS": "OFF",
        "SECP256K1_BUILD_BENCH": "OFF",
        "SECP256K1_BUILD_EXAMPLES": "OFF",
        "SECP256K1_BUILD_MUSIG2": "ON",
        "SECP256K1_BUILD_FROST": "OFF",
        "SECP256K1_BUILD_ZK": "OFF",
        "SECP256K1_BUILD_ECIES": "OFF",
        "SECP256K1_BUILD_BIP352": "OFF",
        "SECP256K1_BUILD_LTC_SP": "OFF",
        "SECP256K1_BUILD_ADAPTOR": "OFF",
        "SECP256K1_BUILD_WALLET": "OFF",
        "SECP256K1_BUILD_PIPPENGER": "ON",
        "SECP256K1_BUILD_ETHEREUM": "OFF",
        "SECP256K1_BUILD_BCH": "OFF"
      }
    },
    {
      "name": "bitcoin-core",
      "displayName": "Bitcoin Core Backend",
      "description": "Minimal footprint for Bitcoin Core fork integration. Strips FROST/ZK/ECIES/BIP352/Adaptor/Wallet/Pippenger \u2014 eliminates verify I-cache regression vs bundled libsecp256k1 without LTO.",
      "inherits": "base-coin",
      "cacheVariables": {
        "SECP256K1_BUILD_SHIM": "ON",
        "SECP256K1_BUILD_BIP324": "ON",
        "SECP256K1_USE_LTO": "OFF"
      }
    },
    {
      "name": "litecoin",
      "displayName": "Litecoin Core Backend",
      "description": "Minimal footprint for Litecoin Core fork. Taproot enabled (activated May 2023). No BIP-324 (LTC P2P is v1 only).",
      "inherits": "base-coin",
      "cacheVariables": {
        "SECP256K1_BUILD_SHIM": "ON",
        "SECP256K1_BUILD_BIP324": "OFF",
        "SECP256K1_USE_LTO": "OFF"
      }
    },
    {
      "name": "dogecoin",
      "displayName": "Dogecoin Core Backend",
      "description": "Minimal footprint for Dogecoin Core. ECDSA + Schnorr only (DOGE doesn't use Taproot or MuSig2). No BIP-324.",
      "inherits": "base-coin",
      "cacheVariables": {
        "SECP256K1_BUILD_SHIM": "ON",
        "SECP256K1_BUILD_BIP324": "OFF",
        "SECP256K1_BUILD_MUSIG2": "OFF",
        "SECP256K1_USE_LTO": "OFF"
      }
    },
    {
      "name": "bch-wallet",
      "displayName": "BCH Wallet (RPA + HD)",
      "description": "BCH with RPA scanning, HD wallet (BIP-32/39), ECIES. No FROST/ZK. Pippenger ON for batch ops.",
      "inherits": "base-coin",
      "cacheVariables": {
        "SECP256K1_BUILD_BCH": "ON",
        "SECP256K1_BUILD_WALLET": "ON",
        "SECP256K1_BUILD_ECIES": "ON",
        "SECP256K1_BUILD_PIPPENGER": "ON",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_BENCH": "ON"
      }
    },
    {
      "name": "wallet",
      "displayName": "Wallet Build (BIP-352 + adaptor + HD)",
      "description": "Full wallet: BIP-32/39, BIP-352 Silent Payments, adaptor sigs, ECIES, MuSig2. No ZK/FROST.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_MUSIG2": "ON",
        "SECP256K1_BUILD_FROST": "OFF",
        "SECP256K1_BUILD_ZK": "OFF",
        "SECP256K1_BUILD_ECIES": "ON",
        "SECP256K1_BUILD_BIP352": "ON",
        "SECP256K1_BUILD_ADAPTOR": "ON",
        "SECP256K1_BUILD_WALLET": "ON",
        "SECP256K1_BUILD_PIPPENGER": "ON",
        "SECP256K1_BUILD_BIP324": "OFF",
        "SECP256K1_BUILD_ETHEREUM": "OFF",
        "SECP256K1_BUILD_BCH": "OFF",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_BENCH": "ON"
      }
    },
    {
      "name": "audit",
      "displayName": "Full Audit Build (all modules ON)",
      "description": "All optional modules enabled for CAAS audit \u2014 matches ci_local.sh --full profile.",
      "inherits": "cpu-release",
      "cacheVariables": {
        "SECP256K1_BUILD_MUSIG2": "ON",
        "SECP256K1_BUILD_FROST": "ON",
        "SECP256K1_BUILD_ZK": "ON",
        "SECP256K1_BUILD_ECIES": "ON",
        "SECP256K1_BUILD_BIP352": "ON",
        "SECP256K1_BUILD_ADAPTOR": "ON",
        "SECP256K1_BUILD_WALLET": "ON",
        "SECP256K1_BUILD_PIPPENGER": "ON",
        "SECP256K1_BUILD_BIP324": "ON",
        "SECP256K1_BUILD_ETHEREUM": "ON",
        "SECP256K1_BUILD_BCH": "OFF"
      }
    },
    {
      "name": "cpu-asan",
      "displayName": "CPU ASan+UBSan",
      "description": "CPU debug with AddressSanitizer + UndefinedBehaviorSanitizer",
      "inherits": "base-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_USE_ASM": "OFF",
        "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-sanitize-recover=all -fno-omit-frame-pointer",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-sanitize-recover=all -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "cpu-tsan",
      "displayName": "CPU TSan",
      "description": "CPU debug with ThreadSanitizer (for multi-threaded tests)",
      "inherits": "base-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_USE_ASM": "OFF",
        "CMAKE_C_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread"
      }
    },
    {
      "name": "conformance",
      "displayName": "CAAS Conformance Vectors (shim BIP-340/341/327)",
      "description": "libsecp256k1-shim conformance tests (official BIP-340/341/327 vectors + bip-0327 reference.py oracle). Mirrors .github/workflows/conformance-vectors.yml job 'conformance'. Add -DCMAKE_CXX_COMPILER / -DSECP256K1_MARCH per environment.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_OPENCL": "OFF",
        "SECP256K1_BUILD_SHIM": "OFF",
        "SECP256K1_SHIM_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_TESTS": "OFF",
        "SECP256K1_BUILD_MUSIG2": "ON"
      }
    },
    {
      "name": "cross-libsecp",
      "displayName": "CAAS Differential vs libsecp256k1 (in-process)",
      "description": "Builds test_cross_libsecp256k1 (FetchContents bitcoin-core/secp256k1 v0.6.0; engine==libsecp byte-match). Mirrors conformance-vectors.yml job 'differential-libsecp'.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_OPENCL": "OFF",
        "SECP256K1_BUILD_TESTS": "ON",
        "SECP256K1_BUILD_CROSS_TESTS": "ON"
      }
    },
    {
      "name": "bch-gpu",
      "displayName": "BCH Wallet + GPU (CUDA RPA scanning)",
      "description": "bch-wallet plus CUDA GPU for batch RPA / silent-payment scanning.",
      "inherits": "bch-wallet",
      "cacheVariables": {
        "SECP256K1_BUILD_CUDA": "ON",
        "CMAKE_CUDA_ARCHITECTURES": "native",
        "CMAKE_CUDA_SEPARABLE_COMPILATION": "ON"
      }
    },
    {
      "name": "embedded",
      "displayName": "Embedded (minimal CPU, size-optimized)",
      "description": "Minimal CPU-only: core ECDSA/Schnorr, no GPU, no optional modules, MinSizeRel.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "SECP256K1_BUILD_CPU": "ON",
        "SECP256K1_BUILD_CUDA": "OFF",
        "SECP256K1_BUILD_OPENCL": "OFF",
        "SECP256K1_BUILD_TESTS": "OFF",
        "SECP256K1_BUILD_BENCH": "OFF",
        "SECP256K1_BUILD_MUSIG2": "OFF",
        "SECP256K1_BUILD_FROST": "OFF",
        "SECP256K1_BUILD_ZK": "OFF",
        "SECP256K1_BUILD_ECIES": "OFF",
        "SECP256K1_BUILD_BIP352": "OFF",
        "SECP256K1_BUILD_ADAPTOR": "OFF",
        "SECP256K1_BUILD_WALLET": "OFF",
        "SECP256K1_BUILD_BCH": "OFF",
        "SECP256K1_BUILD_ETHEREUM": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "cpu-release",
      "configurePreset": "cpu-release"
    },
    {
      "name": "windows-clang-cl",
      "configurePreset": "windows-clang-cl"
    },
    {
      "name": "cpu-release-speed",
      "configurePreset": "cpu-release-speed"
    },
    {
      "name": "cpu-debug",
      "configurePreset": "cpu-debug"
    },
    {
      "name": "cuda-release",
      "configurePreset": "cuda-release"
    },
    {
      "name": "cuda-debug",
      "configurePreset": "cuda-debug"
    },
    {
      "name": "cuda-release-5060ti",
      "configurePreset": "cuda-release-5060ti"
    },
    {
      "name": "cpu-asan",
      "configurePreset": "cpu-asan"
    },
    {
      "name": "cpu-tsan",
      "configurePreset": "cpu-tsan"
    },
    {
      "name": "bitcoin-core",
      "configurePreset": "bitcoin-core"
    },
    {
      "name": "litecoin",
      "configurePreset": "litecoin"
    },
    {
      "name": "dogecoin",
      "configurePreset": "dogecoin"
    },
    {
      "name": "bch-wallet",
      "configurePreset": "bch-wallet"
    },
    {
      "name": "wallet",
      "configurePreset": "wallet"
    },
    {
      "name": "audit",
      "configurePreset": "audit"
    },
    {
      "name": "cuda-audit",
      "configurePreset": "cuda-release"
    },
    {
      "name": "cuda-audit-5060ti",
      "configurePreset": "cuda-release-5060ti"
    }
  ],
  "testPresets": [
    {
      "name": "cpu-release",
      "configurePreset": "cpu-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cpu-debug",
      "configurePreset": "cpu-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cpu-asan",
      "configurePreset": "cpu-asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cpu-tsan",
      "configurePreset": "cpu-tsan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "cuda-audit",
      "configurePreset": "cuda-release",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^(gpu_abi_gate|gpu_ops_equivalence|gpu_host_api_negative|gpu_backend_matrix|unified_audit)$"
        }
      }
    },
    {
      "name": "cuda-audit-5060ti",
      "configurePreset": "cuda-release-5060ti",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^(gpu_abi_gate|gpu_ops_equivalence|gpu_host_api_negative|gpu_backend_matrix|unified_audit)$"
        }
      }
    }
  ]
}
