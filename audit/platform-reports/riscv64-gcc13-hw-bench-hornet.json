{
  "library": "UltrafastSecp256k1",
  "version": "3.14.0",
  "benchmark": "bench_hornet (Bitcoin Consensus CPU Benchmark)",
  "target": "Hornet Node (hornetnode.org)",
  "timestamp": "2026-03-02",
  "platform": {
    "cpu": "SiFive U74-MC (rv64imafdc_zba_zbb) @ 1.5 GHz",
    "board": "Milk-V Mars (StarFive VisionFive 2)",
    "arch": "RISC-V 64 (rv64gc_zba_zbb)",
    "cores": 4,
    "cores_used": 1,
    "ram_gb": 3.8,
    "compiler": "GCC 13.3.0 (cross-compiled, riscv64-linux-gnu)",
    "os": "Debian (Linux 6.6.20-starfive)",
    "build": "Release (-O3, -march=rv64gc_zba_zbb)"
  },
  "config": {
    "field": "4x64 limbs, Montgomery reduction",
    "scalar": "4x64 limbs, Barrett/GLV",
    "point_mul": "GLV endomorphism + wNAF (w=5)",
    "dual_mul": "Shamir's trick (a*G + b*P)",
    "timer": "chrono::high_resolution_clock",
    "warmup": 500,
    "passes": 11,
    "method": "IQR outlier removal + median",
    "pool_size": 64
  },
