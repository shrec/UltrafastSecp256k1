    "batch_verification_n64": {
      "schnorr_per_sig_ns": 605455.4,
      "schnorr_vs_individual": 0.44,
      "ecdsa_per_sig_ns": 246600.9,
      "ecdsa_vs_individual": 0.95
    },
    "key_generation": {
      "pubkey_create_ns": 40601.3,
