    "serialization": {
      "pubkey_compress_ns": 5658.8,
      "ecdsa_der_encode_ns": 457.1,
      "schnorr_bytes_ns": 149.5
    },
    "constant_time": {
      "ct_ecdsa_sign_ns": 159246.0,
      "ct_overhead_ecdsa": 1.96,
      "ct_schnorr_sign_ns": 133446.2,
      "ct_overhead_schnorr": 2.37
    }
  },
  "apple_to_apple": {
    "reference": "libsecp256k1 (bitcoin-core v0.7.2)",
    "config": "default (64-bit field, precomputed tables)",
    "modules": "ECDSA + Schnorr (BIP-340) + extrakeys",
    "method": "100 iterations, 20 warmup, chrono::high_resolution_clock",
    "note": "libsecp256k1 is ALWAYS constant-time; FAST comparison is unfair for signing ops",
    "fast_vs_libsecp": [
      {"op": "Generator*k", "ours_ns": 40601, "theirs_ns": 124986, "speedup": 3.08},
      {"op": "ECDSA Sign", "ours_ns": 81248, "theirs_ns": 164348, "speedup": 2.02},
      {"op": "ECDSA Verify", "ours_ns": 235495, "theirs_ns": 220342, "speedup": 0.94, "note": "libsecp256k1 wins"},
      {"op": "Schnorr Keypair", "ours_ns": 46297, "theirs_ns": 125382, "speedup": 2.71},
      {"op": "Schnorr Sign", "ours_ns": 56374, "theirs_ns": 132827, "speedup": 2.36},
      {"op": "Schnorr Verify", "ours_ns": 239438, "theirs_ns": 224200, "speedup": 0.94, "note": "libsecp256k1 wins"}
    ],
    "fast_summary": "UltrafastSecp256k1 FAST wins 4/6 (2.02x-3.08x); libsecp256k1 wins Verify ops (0.94x)",
    "ct_vs_libsecp": [
      {"op": "ECDSA Sign", "ours_ct_ns": 159246, "theirs_ns": 164348, "speedup": 1.03, "note": "essentially tied"},
      {"op": "ECDSA Verify", "ours_ns": 235495, "theirs_ns": 220342, "speedup": 0.94, "note": "libsecp256k1 wins; verify is public-input, no CT needed"},
      {"op": "Schnorr Sign", "ours_ct_ns": 133446, "theirs_ns": 132827, "speedup": 1.00, "note": "dead even"},
      {"op": "Schnorr Verify", "ours_ns": 239438, "theirs_ns": 224200, "speedup": 0.94, "note": "libsecp256k1 wins; verify is public-input, no CT needed"}
    ],
    "ct_summary": "CT-vs-CT: signing ops tied (1.00x-1.03x); libsecp256k1 wins both verify ops (0.94x)"
  },
